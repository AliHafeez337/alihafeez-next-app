# Required: at least one LLM provider
# Get key: https://aistudio.google.com/apikey
# After adding key, run: npm run build:index  (embeds docs for semantic search)
GEMINI_API_KEY=
GROQ_API_KEY=
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-1.5-flash
GROQ_MODEL=llama-3.1-8b-instant

# Contact (used in chat tools + mailto)
CONTACT_EMAIL=alihafeez337@gmail.com
WHATSAPP_URL=https://wa.me/+923125925295
KOALENDAR_URL=https://koalendar.com/u/ali-hafeez

# Optional: Upstash for production rate limits
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: security event log (no email)
ENABLE_SECURITY_LOG=false

CHAT_MAX_MESSAGE_CHARS=280
CHAT_RATE_LIMIT_PER_MIN=10
CHAT_RATE_LIMIT_PER_DAY=80

# Optional — NOT used by the AI chat. Only for a future contact form on the site.
# Leave empty unless you use Formspree, Slack, Zapier, etc. Example:
# CONTACT_WEBHOOK_URL=https://formspree.io/f/your_form_id
CONTACT_WEBHOOK_URL=
